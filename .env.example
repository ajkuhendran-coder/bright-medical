# Bright Medical — lokale Umgebungsvariablen
# Kopiere diese Datei zu `.env` (die ist in .gitignore) und trage die echten Werte ein.
# Dieselben Variablen gehören in Netlify → Site settings → Environment variables.
# Den service_role-Key NIE ins Frontend, ins Repo oder in einen Chat geben.

# Supabase — Klient-Portal "Mein Programm" (EU/Frankfurt)
SUPABASE_URL=https://xgxkbiycofvevicukztt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=            # GEHEIM: Supabase Dashboard → Project Settings → API → "service_role"

# JWT-Secret für signierte Links (Termin/Vereinbarung/Portal) — existiert i. d. R. schon in Netlify
BRIGHT_JWT_SECRET=
